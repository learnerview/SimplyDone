# Production Configuration

PORT=8080
SPRING_PROFILES_ACTIVE=prod,api,worker

# Database (PostgreSQL)
SPRING_DATASOURCE_URL=jdbc:postgresql://db-host:5432/simplydone
SPRING_DATASOURCE_USERNAME=simplydone_user
SPRING_DATASOURCE_PASSWORD=strong_database_password_here

# Redis Cache
REDIS_URL=redis://redis-host:6379

# Admin Provisioning
# CRITICAL: Store this secret securely in your infrastructure (e.g., AWS Secrets Manager, Vault, Kubernetes Secret)
# Never commit this to version control or logs
ADMIN_INITIAL_SECRET=generate_strong_random_value_here

# Email Service (SMTP)
# Recommended: Use SendGrid or AWS SES for production reliability
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=sendgrid_api_key_here

# Application URL (for email links and redirects)
APP_URL=https://api.yourdomain.com

# JVM Memory Configuration
JAVA_TOOL_OPTIONS=-Xmx1g -Xms512m -XX:+UseG1GC -XX:MaxGCPauseMillis=200