PORT=8080
SPRING_PROFILES_ACTIVE=prod

# Database (Postgres)
SPRING_DATASOURCE_URL=jdbc:postgresql://<HOST>:5432/simplydone
SPRING_DATASOURCE_USERNAME=simplydone
SPRING_DATASOURCE_PASSWORD=change_me_here

# Redis
REDIS_URL=redis://<HOST>:6379

# Admin provisioning
# Provide an out-of-band secret used to create the initial admin API key during first startup.
# This secret must be stored in the platform secret store and NOT committed.
ADMIN_INITIAL_SECRET=change_me_strong_random_value

# Optional: service URLs used for demo or notifications
#NOTIFY_URL=

JAVA_TOOL_OPTIONS=-Xmx384m -Xms256m -XX:+UseG1GC -XX:MaxGCPauseMillis=200