# SimplyDone Environment Configuration Template
# Copy this to .env and fill in your values

# Server
PORT=8080

# Database (use postgresql:// scheme — entrypoint.sh converts it to a JDBC URL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/simplydone

# Redis (standard Valkey/Redis port 6379; docker-compose maps it to 6380 on the host)
REDIS_URL=redis://localhost:6379

# Email (SMTP)
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_ENABLED=true

# File Upload
UPLOAD_DIR=./uploads
